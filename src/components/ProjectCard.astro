---
interface Props { name: string; description: string; tags: string[]; repo: string; }
const { name, description, tags, repo } = Astro.props;
---
<article class="card"><h2>{name}</h2><p>{description}</p><div class="tags">{tags.map((tag) => <span class="tag">{tag}</span>)}</div><a class="repo" href={repo}>{repo.replace("https://", "")}</a></article>
